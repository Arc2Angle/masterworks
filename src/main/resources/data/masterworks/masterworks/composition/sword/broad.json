{
    "components": [
        "blade",
        "guard",
        "handle"
    ],
    "roles": {
        "masterworks:item": {
            "type": "masterworks:compositor",
            "blade": "masterworks:component/sword/broad/blade",
            "guard": "masterworks:component/sword/broad/guard",
            "handle": "masterworks:component/sword/broad/handle"
        }
    },
    "properties": {
        "masterworks:durability": "$blade + $handle + $guard",
        "masterworks:attack_damage": "$blade",
        "masterworks:attack_speed": "$blade * 0.4 + $handle * 0.4 + $guard * 0.2"
    }
}